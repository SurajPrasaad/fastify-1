## 5. ICE Candidate Exchange Flow

```
  User A                     Signaling                      User B
    │                           │                              │
    │  [RTCPeerConnection       │                              │
    │   onicecandidate fires]   │                              │
    │                           │                              │
    │──ice-candidate {          │                              │
    │   type: 'srflx',         │ ── relay via Redis pub/sub ─▶│
    │   candidate: '...',      │                              │  [addIceCandidate]
    │   sdpMLineIndex: 0       │                              │
    │  }                       │                              │
    │                           │                              │
    │──ice-candidate {          │                              │
    │   type: 'relay',         │ ── relay via Redis pub/sub ─▶│
    │   candidate: '...',      │                              │  [addIceCandidate]
    │   sdpMLineIndex: 0       │                              │
    │  }                       │                              │
    │                           │                              │
    │                           │                              │──ice-candidate {
    │  [addIceCandidate]       │◀── relay via Redis pub/sub ──│   type: 'host',
    │                           │                              │   candidate: '...'
    │                           │                              │  }
    │                           │                              │
    │  [ICE connectivity       │                              │  [ICE connectivity
    │   checks: STUN binding   │                              │   checks complete]
    │   requests between        │                              │
    │   candidate pairs]        │                              │
    │                           │                              │
    │◄══════ Selected pair: srflx ←→ host (P2P direct) ══════▶│
    │         OR                │                              │
    │◄══════ Selected pair: relay ←→ relay (via TURN) ════════▶│
```

**ICE Candidate Buffering (for out-of-order arrivals):**
```typescript
// Buffer ICE candidates if remote description not yet set
const iceBuffer = new Map<string, RTCIceCandidateInit[]>();

async function handleRemoteIceCandidate(callId: string, candidate: RTCIceCandidateInit) {
  const callState = await redis.hget(`call:${callId}`, 'state');
  
  if (callState === 'CONNECTING') {
    // Remote description not yet applied — buffer in Redis
    await redis.rpush(`ice:${callId}:buffer`, JSON.stringify(candidate));
    await redis.expire(`ice:${callId}:buffer`, 60);
    return;
  }
  
  // Forward immediately
  await publishSignal(targetUserId, {
    type: 'ICE_CANDIDATE',
    callId,
    candidate,
  });
}

// Flush buffer after remote description is set
async function flushIceBuffer(callId: string, targetUserId: string) {
  const buffered = await redis.lrange(`ice:${callId}:buffer`, 0, -1);
  await redis.del(`ice:${callId}:buffer`);
  
  for (const raw of buffered) {
    await publishSignal(targetUserId, {
      type: 'ICE_CANDIDATE',
      callId,
      candidate: JSON.parse(raw),
    });
  }
}
```

