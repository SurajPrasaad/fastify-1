## 13. Autoscaling & Capacity Planning

### 13.1 HPA Configurations

**WS Gateway Pods:**
```yaml
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: ws-gateway-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: ws-gateway
  minReplicas: 50
  maxReplicas: 500
  behavior:
    scaleUp:
      stabilizationWindowSeconds: 30
      policies:
        - type: Percent
          value: 50     # Scale up 50% at a time
          periodSeconds: 30
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
        - type: Percent
          value: 10     # Scale down 10% at a time
          periodSeconds: 60
  metrics:
    - type: Pods
      pods:
        metric:
          name: ws_active_connections
        target:
          type: AverageValue
          averageValue: "15000"    # Target 15K conn/pod (75% of 20K capacity)
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          targetAverageUtilization: 60
    - type: Pods
      pods:
        metric:
          name: network_rx_bytes_per_second
        target:
          type: AverageValue
          averageValue: "50000000"  # 50 MB/s
```

**coturn Pods:**
```yaml
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: coturn-hpa
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: coturn
  minReplicas: 20
  maxReplicas: 200
  metrics:
    - type: Pods
      pods:
        metric:
          name: turn_active_allocations
        target:
          type: AverageValue
          averageValue: "700"       # Target 70% of 1000 quota
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          targetAverageUtilization: 50
```

### 13.2 Graceful Pod Draining

```typescript
// On SIGTERM (K8s pod termination)
process.on('SIGTERM', async () => {
  logger.info('SIGTERM received, starting graceful shutdown');

  // 1. Stop accepting new connections
  server.close();

  // 2. Notify all connected clients to reconnect
  for (const socket of activeSockets.values()) {
    socket.emit('system:reconnect', {
      reason: 'MAINTENANCE',
      retryAfterMs: 1000 + Math.random() * 4000, // Staggered 1-5s
    });
  }

  // 3. Wait for active calls to drain (max 30s)
  const drainDeadline = Date.now() + 30_000;
  while (activeCallCount > 0 && Date.now() < drainDeadline) {
    await sleep(1000);
  }

  // 4. Force-close remaining connections
  for (const socket of activeSockets.values()) {
    socket.disconnect(true);
  }

  // 5. Cleanup Redis entries for this pod
  await cleanupPodPresence(POD_ID);

  process.exit(0);
});
```

